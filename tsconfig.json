{
    "compilerOptions": {
        "target": "ES2017",
        "module": "commonjs",
        "lib": ["es2017"],
        "declaration": true,
        "strict": false,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "moduleResolution": "node",
        "rootDir": ".",
        "outDir": "ts-out"
    },
    "exclude": [
        "ts-out",
        "node_modules"
    ]
}
